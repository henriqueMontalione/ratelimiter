PORT=8080

# Rate limiting - IP
IP_RATE_LIMIT=10

# Rate limiting - Token (default para qualquer token)
TOKEN_RATE_LIMIT=20

# Limites individuais por token: token:limite,token:limite
# TOKEN_LIMITS=abc123:100,vip-key:500

# Tempo de bloqueio em segundos após exceder o limite
BLOCK_DURATION_SECONDS=300

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
